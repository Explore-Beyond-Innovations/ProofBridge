# EVM deploy env — consumed by scripts/deploy/deploy-contracts.sh via
# `--evm-env <file>`. Copy, rename per-network, fill in, then run:
#
#   cp scripts/deploy/.env.evm.example scripts/deploy/.env.sepolia
#   $EDITOR scripts/deploy/.env.sepolia
#   bash scripts/deploy/deploy-contracts.sh --chains evm,stellar \
#     --tag latest \
#     --evm-env scripts/deploy/.env.sepolia \
#     --stellar-env scripts/deploy/.env.stellar-testnet

# ── required ────────────────────────────────────────────────────────
# RPC endpoint for the target network (Sepolia / mainnet / etc.)
EVM_RPC_URL=https://sepolia.infura.io/v3/<YOUR_KEY>

# Deployer private key. Must be funded with enough native gas token.
# Gets MANAGER_ROLE on the deployed AdManager + OrderPortal unless
# ADMIN below is set.
EVM_ADMIN_PRIVATE_KEY=0x

# ── optional ────────────────────────────────────────────────────────
# Override the address granted MANAGER_ROLE. Defaults to the deployer.
# ADMIN=0x

# Human-readable name written into the manifest. Defaults to `evm-<chainId>`.
CHAIN_NAME=sepolia

# Free-form environment tag written into the manifest (local|testnet|mainnet).
DEPLOY_ENV=testnet

# Wrapped-native metadata deployed alongside the core contracts.
# WNATIVE_NAME=Wrapped Ether
# WNATIVE_SYMBOL=WETH
# WNATIVE_DECIMALS=18
