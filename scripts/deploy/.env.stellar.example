# Stellar deploy env — consumed by scripts/deploy/deploy-contracts.sh via
# `--stellar-env <file>`. Copy, rename per-network, fill in, then run:
#
#   cp scripts/deploy/.env.stellar.example scripts/deploy/.env.stellar-testnet
#   $EDITOR scripts/deploy/.env.stellar-testnet
#   bash scripts/deploy/deploy-contracts.sh --chains evm,stellar \
#     --tag latest \
#     --evm-env scripts/deploy/.env.sepolia \
#     --stellar-env scripts/deploy/.env.stellar-testnet
#
# Prereq: create a funded Stellar CLI identity once:
#   stellar keys generate admin --network testnet --fund
# (or `stellar keys add admin --secret-key S...` to import an existing one.)

# ── optional (sensible defaults) ────────────────────────────────────
# Stellar network passphrase target. `testnet` | `futurenet` | `mainnet`
# or a custom network registered via `stellar network add`.
STELLAR_NETWORK=testnet

# `stellar keys` identity used as --source for every stellar CLI call.
# Must already exist locally and be funded on the target network.
STELLAR_SOURCE_ACCOUNT=admin

# Human-readable name written into the manifest. Defaults to `stellar-1000001`.
CHAIN_NAME=stellar-testnet

# Free-form environment tag written into the manifest (local|testnet|mainnet).
DEPLOY_ENV=testnet
