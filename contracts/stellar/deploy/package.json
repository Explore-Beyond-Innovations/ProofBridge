{
  "name": "@proofbridge/stellar-deploy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Per-chain deploy / link / test-token CLI for the Stellar side of ProofBridge. Emits the shared chain deployment manifest.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "stellar-deploy": "bin/cli.ts"
  },
  "scripts": {
    "cli": "tsx bin/cli.ts",
    "deploy": "tsx bin/cli.ts deploy",
    "link": "tsx bin/cli.ts link",
    "deploy-test-tokens": "tsx bin/cli.ts deploy-test-tokens"
  },
  "dependencies": {
    "@proofbridge/deployment-manifest": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
