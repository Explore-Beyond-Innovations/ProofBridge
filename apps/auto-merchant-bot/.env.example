# Auto-merchant-bot env — copy to .env and fill in, then `pnpm --filter
# @proofbridge/auto-merchant-bot start`.

# ── backend ─────────────────────────────────────────────────────────
BACKEND_URL=https://api.pfbridge.xyz

# ── admin wallets (one user, two wallets linked) ────────────────────
# The bot logs in with the EVM wallet and then links the Stellar one so a
# single user owns ads on both chains. The lock endpoint matches the
# caller's linked wallet against the ad's chain kind.

# Sepolia admin private key (0x-prefixed, 32 bytes).
EVM_ADMIN_PRIVATE_KEY=

# Stellar admin ed25519 secret seed (S...).
STELLAR_ADMIN_SECRET=

# ── RPCs ────────────────────────────────────────────────────────────
EVM_RPC_URL=
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── SIWE envelope (optional; must match what the backend was deployed
# with if set). If unset, the bot reads them from the challenge response —
# usually the right default. Override only if you've pinned a different
# domain than the backend returns.
SIGN_DOMAIN=app.pfbridge.xyz
SIGN_URI=https://app.pfbridge.xyz

# ── tuning ──────────────────────────────────────────────────────────
# Milliseconds between poll ticks.
POLL_INTERVAL_MS=5000

# Milliseconds the lock-for-order authorisation stays valid on-chain.
LOCK_TIME_TO_EXPIRE_MS=300000

# 1 = log "would lock X" but skip the /lock → chain → /confirm round trip.
# Recommended for first run against a new backend deployment.
DRY_RUN=1
